{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "apps/**/*.ts",
    "packages/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
